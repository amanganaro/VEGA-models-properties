                <Value>1</Value>
                <Label>Toxic</Label>
            </Class>
            <Class>
                <Value>-1</Value>
                <Label>Not predicted</Label>
            </Class>
        </ClassValues>
    </Vega>

    <Guide></Guide>

    <Reference></Reference>

    <Endpoint></Endpoint>

    <Stats></Stats>
    
</xml>