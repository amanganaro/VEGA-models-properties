<xml>
   
    <Version>
        <Name>Sludge Classification Toxicity model (ProtoQSAR-Combase)</Name>
        <Key>SLUDGE_COMBASECLASS</Key>
        <Summary>Classification model for toxicity in sludge, specific for biocides</Summary>
        <Version>1.0.0</Version>
    </Version>
    
    <Vega>
        <TS>/data/ts_sludge_combaseClass.dat</TS>
        <LocalQMRF>/data/QMRF_sludge_life.pdf</LocalQMRF>
