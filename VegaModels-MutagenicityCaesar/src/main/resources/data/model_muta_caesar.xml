<xml>
   
    <Version>
        <Name>Mutagenicity (Ames test) model (CAESAR)</Name>
        <Key>MUTA_CAESAR</Key>
        <Summary>QSAR classification model for Mutagenicity (from CAESAR project)</Summary>
        <Version>2.1.13</Version>
    </Version>
    
    <Vega>
        <TS>/data/ts_muta_caesar.dat</TS>
        <QMRF>http://qsardb.jrc.it/qmrf/search_catalogs.jsp?id=429</QMRF>
        <HasAlerts>True</HasAlerts>
        <ClassValues>
            <Class>
                <Value>0</Value>
                <Label>NON-Mutagenic</Label>
            </Class>
            <Class>
                <Value>1</Value>
                <Label>Mutagenic</Label>
            </Class>
            <Class>
                <Value>2</Value>
                <Label>Suspect Mutagenic</Label>
            </Class>
            <Class>
                <Value>-1</Value>
                <Label>Not classifiable</Label>
            </Class>
        </ClassValues>
    </Vega>

    <Guide></Guide>

    <Reference></Reference>

    <Endpoint></Endpoint>

    <Stats></Stats>
    
</xml>