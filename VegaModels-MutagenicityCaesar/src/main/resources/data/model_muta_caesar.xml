<xml>
   
    <Version>
        <Name>Mutagenicity (Ames test) model (CAESAR)</Name>
        <Key>MUTA_CAESAR</Key>
        <Summary>QSAR classification model for Mutagenicity (from CAESAR project)</Summary>
        <Version>2.1.14</Version>
    </Version>
    
    <Vega>
        <TS>/data/ts_muta_caesar.dat</TS>
        <QMRF>/data/muta_caesar/qmrf_muta_caesar.xml</QMRF>
        <HasAlerts>True</HasAlerts>
        <ClassValues>
            <Class>
                <Value>0</Value>
                <Label>NON-Mutagenic</Label>
            </Class>
            <Class>
                <Value>1</Value>
                <Label>Mutagenic</Label>
            </Class>
            <Class>
                <Value>2</Value>
                <Label>Suspect Mutagenic</Label>
            </Class>
            <Class>
                <Value>-1</Value>
                <Label>Not classifiable</Label>
            </Class>
        </ClassValues>
    </Vega>

</xml>